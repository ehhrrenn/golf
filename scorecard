<!DOCTYPE html>
<html>
<head>
    <title>Pro Golf Scorecard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://unpkg.com" />
    <style>
        body { font-family: sans-serif; padding: 15px; background: #f0f2f5; max-width: 600px; margin: auto; }
        .card { background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 15px; }
        input, select, button { width: 100%; padding: 12px; margin: 5px 0; border-radius: 5px; border: 1px solid #ccc; box-sizing: border-box; }
        button { background: #2ecc71; color: white; border: none; font-weight: bold; cursor: pointer; }
        #map { height: 250px; width: 100%; border-radius: 8px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 10px; border-bottom: 1px solid #eee; text-align: center; }
    </style>
</head>
<body onload="initMap()">

    <div class="card">
        <h3>🔍 Find Course Scorecard</h3>
        <input type="text" id="courseInput" placeholder="Enter Course Name...">
        <button onclick="findCourse()">Search</button>
        <select id="courseSelect" style="display:none" onchange="loadScorecard(this.value)"></select>
    </div>

    <div class="card">
        <div id="map"></div>
        <p id="distText" style="text-align:center; font-weight:bold; font-size:1.2em;">Distance: -- yds</p>
    </div>

    <div class="card">
        <h3>📝 Enter Score</h3>
        <form id="scoreForm">
            <input type="text" name="player" placeholder="Player Name" required>
            <input type="number" name="hole" id="holeInput" placeholder="Hole #" required>
            <input type="number" name="score" placeholder="Score" required>
            <input type="number" name="par" id="parInput" placeholder="Par (Auto-filled)">
            <button type="submit">Submit Score</button>
        </form>
    </div>

    <div class="card">
        <h3>🏆 Leaderboard</h3>
        <div id="leaderboard">Loading...</div>
    </div>

    <script src="https://unpkg.com"></script>
    <script>
        const scriptURL = 'PASTE_YOUR_WEB_APP_URL_HERE';
        let scorecardData = {};

        // Search for Course
        async function findCourse() {
            const query = document.getElementById('courseInput').value;
            const res = await fetch(`${scriptURL}?action=searchCourse&query=${query}`);
            const data = await res.json();
            const select = document.getElementById('courseSelect');
            select.innerHTML = '<option>Select your course...</option>';
            data.courses.forEach(c => {
                select.innerHTML += `<option value="${c.id}">${c.course_name}</option>`;
            });
            select.style.display = 'block';
        }

        // Load Pars
        async function loadScorecard(id) {
            const res = await fetch(`${scriptURL}?action=getScorecard&id=${id}`);
            const data = await res.json();
            scorecardData = data; // API response with hole pars
            alert("Scorecard loaded!");
        }

        // Auto-fill Par when typing hole
        document.getElementById('holeInput').addEventListener('input', (e) => {
            const hole = e.target.value;
            if(scorecardData.holes && scorecardData.holes[hole-1]) {
                document.getElementById('parInput').value = scorecardData.holes[hole-1].par;
            }
        });

        // Submit Score
        document.getElementById('scoreForm').addEventListener('submit', e => {
            e.preventDefault();
            fetch(scriptURL, { method: 'POST', body: new FormData(e.target) })
                .then(() => { alert("Saved!"); loadLeaderboard(); e.target.reset(); });
        });

        // Load Leaderboard
        function loadLeaderboard() {
            fetch(scriptURL).then(res => res.json()).then(players => {
                let html = '<table><tr><th>Player</th><th>Holes</th><th>Total</th></tr>';
                players.forEach(p => {
                    html += `<tr><td>${p.name}</td><td>${p.holesPlayed}</td><td>${p.totalScore}</td></tr>`;
                });
                document.getElementById('leaderboard').innerHTML = html + '</table>';
            });
        }

        // Simple GPS Map Init
        function initMap() {
            const map = L.map('map').setView([0,0], 2);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            map.locate({setView: true, watch: true, maxZoom: 18});
            loadLeaderboard();
        }
    </script>
</body>
</html>
